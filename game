            <div id="player-1" class="player-btn rotate-180 relative flex-1 flex flex-col w-full h-full items-center justify-center rounded-3xl md:rounded-[3rem] transition-all duration-150 cursor-pointer overflow-hidden bg-neutral-800/60 border-2 border-neutral-700 opacity-60 scale-[0.98]"></div>
