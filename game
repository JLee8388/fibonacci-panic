            <div id="player-3" class="player-btn relative flex-1 flex flex-col w-full h-full items-center justify-center rounded-3xl md:rounded-[3rem] transition-all duration-150 cursor-pointer overflow-hidden bg-neutral-800/60 border-2 border-neutral-700 opacity-60 scale-[0.98]"></div>
        </div>

    </div>

    <!-- GAME LOGIC SCRIPT -->
    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // Constants
        const PLAYERS = [
            { id: 0, name: 'Red', colorBg: 'bg-rose-500', colorText: 'text-rose-500', shadow: 'shadow-rose-600', key: 'q' },
            { id: 1, name: 'Blue', colorBg: 'bg-blue-600', colorText: 'text-blue-600', shadow: 'shadow-blue-700', key: 'p' },
            { id: 2, name: 'Green', colorBg: 'bg-emerald-500', colorText: 'text-emerald-500', shadow: 'shadow-emerald-600', key: 'z' },
            { id: 3, name: 'Yellow', colorBg: 'bg-amber-400', colorText: 'text-amber-400', shadow: 'shadow-amber-500', key: 'm' },
        ];
        const FIB_TOTAL_SECONDS = [8, 13, 21, 34];
        const FIB_WARNING_SECONDS = [0, 1, 2, 3, 5, 8];

        // State Variables
        let state = 'wake'; // wake, menu, playing, gameover
        let activePlayer = 0;
        let tapsNeeded = 5;
        let tapsDone = 0;
        let timeLeft = 0;
        let totalTime = 0;
        let warningThreshold = 0;
        let soundEnabled = true;
        let gameLoopInterval = null;
        let penalties = {0:false, 1:false, 2:false, 3:false};
        
        let audioCtx = null;

        // DOM Elements
        const elBody = document.getElementById('body-container');
        const elWake = document.getElementById('screen-wake');
        const elMenu = document.getElementById('screen-menu');
        const elGameover = document.getElementById('screen-gameover');
        const elArena = document.getElementById('screen-arena');
        const elSoundControls = document.getElementById('sound-controls');
        const elFlash = document.getElementById('flash-overlay');
        
        const elBombContainer = document.getElementById('bomb-container');
        const elMainBomb = document.getElementById('main-bomb');
        const elBombRing = document.getElementById('bomb-ping-ring');
        
        const elLoserBox = document.getElementById('loser-name-box');
        const elStatsText = document.getElementById('stats-text');
        const btnRestart = document.getElementById('btn-restart');

        // AUDIO SYSTEM
        function initAudio() {
            try {
                if (!audioCtx) {
                    const AudioContext = window.AudioContext || window.webkitAudioContext;
                    audioCtx = new AudioContext();
                }
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                return true;
            } catch (e) {
                console.error("Audio Context failed", e);
                return false;
            }
        }

        function unlockAudio() {
            if (!initAudio()) return;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            gain.gain.value = 0.01;
            osc.start(audioCtx.currentTime);
            osc.stop(audioCtx.currentTime + 0.01);
            
            // Move to menu
            state = 'menu';
            elWake.classList.add('hidden');
            elMenu.classList.remove('hidden');
            elSoundControls.classList.remove('hidden');
        }

        function playSound(type) {
            if (!soundEnabled || !audioCtx) return;
            if (audioCtx.state === 'suspended') audioCtx.resume();

            const now = audioCtx.currentTime;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();

            osc.connect(gain);
            gain.connect(audioCtx.destination);

            if (type === 'tap') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(600, now);
                osc.frequency.exponentialRampToValueAtTime(300, now + 0.1);
                gain.gain.setValueAtTime(0.3, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 0.1);
                osc.start(now);
                osc.stop(now + 0.1);
            } else if (type === 'pass') {
                osc.type = 'square';
                osc.frequency.setValueAtTime(400, now);
                osc.frequency.setValueAtTime(800, now + 0.1);
                gain.gain.setValueAtTime(0.2, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
                osc.start(now);
                osc.stop(now + 0.15);
            } else if (type === 'penalty') {
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(100, now);
                gain.gain.setValueAtTime(0.4, now);
                gain.gain.linearRampToValueAtTime(0.001, now + 0.3);
                osc.start(now);
                osc.stop(now + 0.3);
            } else if (type === 'explode') {
                osc.type = 'square';
                osc.frequency.setValueAtTime(100, now);
                osc.frequency.exponentialRampToValueAtTime(10, now + 1.2);
                gain.gain.setValueAtTime(0.8, now);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 1.2);
                osc.start(now);
                osc.stop(now + 1.2);
            }
        }

        function triggerVibrate(pattern) {
            if (navigator.vibrate) {
                try { navigator.vibrate(pattern); } catch(e) {}
            }
        }

        function triggerFlash(color) {
            elFlash.style.backgroundColor = color;
            elFlash.style.opacity = color === 'white' ? '0.4' : '0.6';
            elFlash.classList.remove('hidden');
            setTimeout(() => {
                elFlash.classList.add('hidden');
            }, 150);
        }

        // RENDER HELPERS
        function renderPlayers() {
            PLAYERS.forEach(player => {
                const el = document.getElementById(`player-${player.id}`);
                const isActive = activePlayer === player.id;
                const isPenalized = penalties[player.id];
                
                // Clear existing classes
                el.className = `player-btn relative flex-1 flex flex-col w-full h-full items-center justify-center rounded-3xl md:rounded-[3rem] transition-all duration-150 cursor-pointer overflow-hidden ${player.id < 2 ? 'rotate-180' : ''}`;
                
                if (isPenalized) {
                    el.classList.add('bg-rose-600', 'border-[6px]', 'border-white', 'z-30', 'animate-violently-shake', 'shadow-[0_0_50px_rgba(225,29,72,0.8)]');
                    el.innerHTML = `
                        <i data-lucide="alert-triangle" class="text-white w-16 h-16 mb-4 animate-bounce"></i>
                        <span class="text-3xl md:text-5xl font-black text-white text-center leading-tight">
                            PENALTY!<br/><span class="text-2xl md:text-4xl">-2 SEC</span>
                        </span>
                    `;
                } else if (isActive) {
                    el.classList.add(player.colorBg, player.shadow, 'shadow-[0_0_40px_rgba(0,0,0,0.6)]', 'scale-[1.02]', 'z-10', 'border-[4px]', 'md:border-[6px]', 'border-white');
                    const percent = (tapsDone / tapsNeeded) * 100;
                    el.innerHTML = `
                        <span class="text-3xl md:text-5xl font-black mb-2 md:mb-4 opacity-90 tracking-wider">${player.name}</span>
                        <div class="h-20 md:h-24 flex items-center justify-center">
                            <div class="flex flex-col items-center animate-bounce-custom">
                                <span class="text-4xl md:text-6xl font-black">TAP!</span>
                                <span class="text-lg md:text-2xl font-bold opacity-80 mt-1">${tapsNeeded - tapsDone} LEFT</span>
                            </div>
                        </div>
                        <div class="absolute bottom-0 left-0 h-4 md:h-6 bg-white/30 transition-all duration-150" style="width: ${percent}%"></div>
                    `;
                } else {
                    el.classList.add('bg-neutral-800/60', 'border-2', 'border-neutral-700', 'opacity-60', 'scale-[0.98]');
                    el.innerHTML = `
                        <span class="text-3xl md:text-5xl font-black mb-2 md:mb-4 opacity-90 tracking-wider">${player.name}</span>
                        <div class="h-20 md:h-24 flex items-center justify-center">
                            <span class="text-sm md:text-xl font-bold opacity-30">Key: ${player.key.toUpperCase()}</span>
                        </div>
                    `;
                }
            });
            lucide.createIcons(); // Re-init icons for injected HTML
        }

        function updateArenaVisuals() {
            if (state !== 'playing') return;
            
            const isCritical = warningThreshold > 0 && timeLeft <= warningThreshold;

            if (isCritical) {
                elBody.classList.remove('bg-neutral-900');
                elBody.classList.add('bg-rose-950');
                elBombContainer.classList.remove('border-neutral-700');
                elBombContainer.classList.add('border-rose-500');
                elMainBomb.classList.remove('text-neutral-400', 'bomb-pulse');
                elMainBomb.classList.add('text-rose-500', 'bomb-ping');
                elBombRing.classList.remove('hidden');
            } else {
                elBody.classList.add('bg-neutral-900');
                elBody.classList.remove('bg-rose-950');
                elBombContainer.classList.add('border-neutral-700');
                elBombContainer.classList.remove('border-rose-500');
                elMainBomb.classList.add('text-neutral-400', 'bomb-pulse');
                elMainBomb.classList.remove('text-rose-500', 'bomb-ping');
                elBombRing.classList.add('hidden');
            }
        }

        // GAME LOGIC
        function startGame() {
            if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
            
            state = 'playing';
            elMenu.classList.add('hidden');
            elGameover.classList.add('hidden');
            elArena.classList.remove('hidden');

            const selectedSeconds = FIB_TOTAL_SECONDS[Math.floor(Math.random() * FIB_TOTAL_SECONDS.length)];
            totalTime = selectedSeconds * 1000;
            
            const possibleWarnings = FIB_WARNING_SECONDS.filter(sec => sec < selectedSeconds);
            const selectedWarningSeconds = possibleWarnings[Math.floor(Math.random() * possibleWarnings.length)];
            warningThreshold = selectedWarningSeconds * 1000;

            timeLeft = totalTime;
            activePlayer = Math.floor(Math.random() * PLAYERS.length);
            tapsNeeded = Math.floor(Math.random() * 4) + 3;
            tapsDone = 0;
            penalties = {0:false, 1:false, 2:false, 3:false};

            elBody.classList.remove('animate-violently-shake');
            updateArenaVisuals();
            renderPlayers();

            if (gameLoopInterval) clearInterval(gameLoopInterval);
            gameLoopInterval = setInterval(() => {
                timeLeft -= 50;
                if (timeLeft <= 0) {
                    clearInterval(gameLoopInterval);
                    handleExplode();
                } else {
                    updateArenaVisuals();
                }
            }, 50);
        }

        function handleExplode() {
            state = 'gameover';
            elArena.classList.add('hidden');
            elGameover.classList.remove('hidden');
            elBody.classList.add('bg-neutral-900');
            elBody.classList.remove('bg-rose-950');

            playSound('explode');
            triggerVibrate([200, 100, 200, 100, 500]);
            triggerFlash('red');

            const loserPlayer = PLAYERS[activePlayer];
            elLoserBox.className = `text-5xl font-bold my-8 py-6 px-10 rounded-3xl inline-block shadow-[0_0_50px_rgba(0,0,0,0.5)] ${loserPlayer.colorBg}`;
            elLoserBox.innerText = `${loserPlayer.name} loses!`;
            
            elStatsText.innerText = `Round length: ${totalTime/1000}s | Warning: ${warningThreshold/1000}s`;

            // Anti-mash lock
            btnRestart.disabled = true;
            btnRestart.className = 'flex items-center gap-3 px-10 py-5 rounded-full font-black text-2xl transition-all duration-300 bg-neutral-800 text-neutral-500 cursor-not-allowed border-2 border-neutral-700 opacity-80';
            document.getElementById('restart-icon').setAttribute('data-lucide', 'lock');
            document.getElementById('restart-text').innerText = 'WAIT...';
            lucide.createIcons();

            setTimeout(() => {
                btnRestart.disabled = false;
                btnRestart.className = 'flex items-center gap-3 px-10 py-5 rounded-full font-black text-2xl transition-all duration-300 bg-white text-neutral-900 hover:bg-neutral-200 active:scale-95 shadow-[0_0_30px_rgba(255,255,255,0.4)]';
                document.getElementById('restart-icon').setAttribute('data-lucide', 'rotate-ccw');
                document.getElementById('restart-text').innerText = 'PLAY AGAIN';
                lucide.createIcons();
            }, 1500);
        }

        function handleTap(playerId) {
            if (state !== 'playing') return;

            // Penalty!
            if (playerId !== activePlayer) {
                playSound('penalty');
                triggerVibrate([100, 50, 100]);
                triggerFlash('red');
                
                elBody.classList.add('animate-violently-shake');
                setTimeout(() => elBody.classList.remove('animate-violently-shake'), 300);

                activePlayer = playerId;
                tapsDone = 0;
                tapsNeeded = Math.floor(Math.random() * 4) + 3;
                timeLeft = Math.max(10, timeLeft - 2000); // -2 seconds

                penalties[playerId] = true;
                renderPlayers();
                
                setTimeout(() => {
                    penalties[playerId] = false;
                    if(state === 'playing') renderPlayers();
                }, 1000);
                return;
            }

            // Normal Tap
            tapsDone++;
            if (tapsDone >= tapsNeeded) {
                playSound('pass');
                triggerVibrate([50, 50, 50]);
                triggerFlash('white');

                let nextId = activePlayer;
                while (nextId === activePlayer) {
                    nextId = Math.floor(Math.random() * PLAYERS.length);
                }
                activePlayer = nextId;
                tapsDone = 0;
                tapsNeeded = Math.floor(Math.random() * 5) + 3;
            } else {
                playSound('tap');
                triggerVibrate(20);
            }
            renderPlayers();
        }

        // EVENT LISTENERS
        elWake.addEventListener('pointerdown', unlockAudio);
        document.getElementById('btn-start').addEventListener('click', startGame);
        btnRestart.addEventListener('click', () => {
            if(!btnRestart.disabled) startGame();
        });

        // Sound Toggle
        document.getElementById('btn-sound').addEventListener('click', () => {
            soundEnabled = !soundEnabled;
            const iconOn = document.getElementById('icon-sound-on');
            const iconOff = document.getElementById('icon-sound-off');
            if (soundEnabled) {
                iconOn.classList.remove('hidden');
                iconOff.classList.add('hidden');
                if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
            } else {
                iconOn.classList.add('hidden');
                iconOff.classList.remove('hidden');
            }
        });

        // Player Buttons (Touch/Mouse)
        PLAYERS.forEach(player => {
            const btn = document.getElementById(`player-${player.id}`);
            btn.addEventListener('pointerdown', (e) => {
                e.preventDefault();
                handleTap(player.id);
            });
        });

        // Keyboard support
        window.addEventListener('keydown', (e) => {
            if (state !== 'playing') return;
            const key = e.key.toLowerCase();
            const player = PLAYERS.find(p => p.key === key);
            if (player) handleTap(player.id);
        });

    </script>
</body>
</html>

