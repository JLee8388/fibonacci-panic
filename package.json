{
  "name": "short-fuse",
  "version": "1.0.0",
  "description": "Short Fuse — a 4-player local pass-and-play party game, wrapped as a native iOS app with Capacitor.",
  "type": "module",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.input.css -o ./www/assets/tailwind.css --minify",
    "build:js": "node ./scripts/build.js",
    "build": "npm run build:css && npm run build:js",
    "watch:js": "node ./scripts/build.js --watch",
    "dev": "npm run build && http-server www -p 8080 -c-1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src scripts tests",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "verify": "npm run lint && npm run test && npm run build",
    "cap:sync": "npm run build && cap sync ios",
    "cap:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "lucide": "^0.460.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@eslint/js": "^9.15.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.1",
    "tailwindcss": "^3.4.15",
    "vitest": "^2.1.6"
  }
}
